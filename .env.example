# Anthropic API key (required)
ANTHROPIC_API_KEY=

# Supabase (required for auth + metadata storage)
# See: https://supabase.com/docs/guides/api/api-keys
# Project ref: bijnngiiffihubunmkfh
NEXT_PUBLIC_SUPABASE_URL=https://bijnngiiffihubunmkfh.supabase.co
# Client-side: use publishable key (sb_publishable_...) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-side only: use secret key (sb_secret_...) or legacy service_role JWT
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Encryption key for connection_string at rest (AES-256-GCM)
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit the real key. Rotate by re-encrypting all rows.
CONNECTION_STRING_ENCRYPTION_KEY=your-64-char-hex-key-here

# Direct database connection (development only)
# Used to bypass Supabase connections and use file-based semantic layer.
# In production, database connections are managed per-user via the UI.
#
# Supabase (https://supabase.com/docs/guides/database/connecting-to-postgres):
# - If you get ENOTFOUND on db.xxx.supabase.co, use a pooler URL instead:
#   • Session pooler (IPv4-friendly): postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#   • Transaction mode (serverless):  postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres
# - Use SSL; set DATABASE_SSL=false only for local dev if needed.
DATABASE_URL=postgresql://user:password@localhost:5432/heydata
