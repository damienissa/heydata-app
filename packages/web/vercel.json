{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@heydata/web",
  "outputDirectory": ".next",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/connections/[id]/semantic/generate/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/connections/[id]/introspect/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/query/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
